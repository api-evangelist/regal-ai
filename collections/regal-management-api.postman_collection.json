    "_postman_id": "790c7dce-0122-4de3-aa9f-e319381baebe",
    "name": "Regal Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Regal Management API exposes listing endpoints over api.regal.ai/v1 for tenant configuration: Business Profiles (used to drive branded caller ID), Active Phone Numbers in the tenant, Outbound Campaigns, and AI Call Dispositions. Introduced in the January 2025 release to enable programmatic onboarding, audit, and reporting.\n\nContact Support:\n Name: Regal Support\n Email: support@regal.ai",
      "type": "text/plain"
    }
  }
