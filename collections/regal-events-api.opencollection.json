{
  "opencollection": "1.0.0",
  "info": {
    "name": "Regal Events API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Events",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Post Custom Event",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://events.regalvoice.com/events",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates or updates a contact profile and records a custom event against the resolved profile. At least one phone or email must be present in traits for the contact to be considered contactable. Events whose name matches a Journey trigger will enroll the contact into that Journey."
        }
      ]
    }
  ],
  "bundled": true
}