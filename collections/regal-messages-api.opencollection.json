{
  "opencollection": "1.0.0",
  "info": {
    "name": "Regal Messages API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Messages",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Send Message",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.regal.ai/v1/messages/send",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Queue an outbound SMS message for delivery."
        }
      ]
    }
  ],
  "bundled": true
}